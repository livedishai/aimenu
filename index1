  <div class="header-mon"></div>
  <p class="header-kanji">日本料理</p>
  <h1 class="header-title">Japanese Cuisine</h1>
  <span class="header-title-jp">日本料理</span>
  <div class="brush-divider"></div>
  <p class="header-sub" id="ui-sub-tag">Authentic Japanese Cuisine</p>
  <span class="ar-badge">
    <span class="ar-dot"></span>
    <span id="ui-ar-badge">Interactive 3D &amp; AR Preview</span>
  </span>
</header>

<nav class="tabs-wrap" aria-label="Menu categories">
  <div class="tabs-inner" id="tabs-inner"></div>
</nav>

<main class="main">
  <div class="state-box" id="loading-state">
    <div class="spinner"></div>
    <p id="ui-loading">読み込み中…</p>
  </div>
  <div id="items-container" style="display:none"></div>
</main>

<div class="modal-overlay" id="modal-overlay" role="dialog" aria-modal="true" aria-label="Dish detail">
  <div class="modal-card">
    <div class="modal-viewer-wrap" id="modal-viewer-wrap">
      <div class="seigaiha-bg"></div>
      <button class="modal-close" id="modal-close" aria-label="Close">✕</button>
      <div class="mv-ar-badge" id="mv-ar-badge">✦ AR Ready</div>
      <div class="scale-info" id="scale-info">Actual portion size</div>
    </div>

    <div class="modal-body">
      <h2 class="modal-name" id="modal-name"></h2>
      <p  class="modal-jp"   id="modal-jp"></p>
      <div class="tags-row"  id="modal-tags"></div>
      <p  class="modal-desc" id="modal-desc"></p>
      <div class="modal-footer">
        <div class="modal-price" id="modal-price"></div>
