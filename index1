</div>

<footer class="site-footer">
  Tap any dish to view in 3D &nbsp;·&nbsp; Prices in ₹ &nbsp;·&nbsp; 🌿 Vegetarian friendly<br>
  <span style="opacity:0.5; font-size:10px;">AR requires a compatible mobile device · Model size reflects actual portion</span>
</footer>

<script>
const DISH_IMAGES = {

  'karamisoramen':    '3d-model/KaramisoRamen/karamisoramen.png',
  'shioramen':        '3d-model/ShioRamen/shioramen.png',
  'shoyuramen':       '3d-model/ShoyuRamen/shoyuramen.png',
  'tantanmen':        '3d-model/Tantanman/Tantanmen.png',
};

const LOCAL_ASSETS = {
   'karamisoramen': { folder: 'KaramisoRamen', file: 'KaramisoRamen', scale: 0.15 },
  'shioramen':     { folder: 'ShioRamen',     file: 'ShioRamen',     scale: 0.2  },
  'shoyuramen':    { folder: 'ShoyuRamen',    file: 'ShoyuRamen',    scale: 0.2  },
  'tantanmen':     { folder: 'Tantanman',     file: 'Tantanman',     scale: 0.15 },
};
const ASSETS_BASE = '3d-model';

function getLocalAssets(dishName) {
  const key = (dishName || '').toLowerCase().trim();
  const entry = LOCAL_ASSETS[key];
  if (!entry) return { posterPath: DISH_IMAGES[key] || '', glbPath: '' };
  const base = `${ASSETS_BASE}/${entry.folder}/${entry.file}`;
  return {
    posterPath: DISH_IMAGES[key] || `${base}.png`,
    glbPath:    `${base}.glb`,
    usdzPath:   `${base}.usdz`,
    scale:      entry.scale,
  };
}

const SHEET_ID  = '1QAReLCzWLQEfNyY9V6Cg5VbGPqmbXh4XCZ_RCQSRlz0';
const SHEET_GID = '0';
const CSV_URL   = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/export?format=csv&gid=${SHEET_GID}`;

const EMOJI_MAP = {
 'karamisoramen': '🍜',
  'shioramen':     '🍜',
  'shoyuramen':    '🍜',
  'tantanmen':     '🍜',
  'gyoza':            '🥟',
  'edamame':          '🫘',
  'karaage':          '🍗',
  'miso soup':        '🍵',
  'takoyaki':         '🐙',
  'agedashi tofu':    '🫕',
  'ramen':            '🍜',
  'salmon sashimi':   '🐟',
  'tempura':          '🍤',
  'matcha ice cream': '🍦',
};

const I18N = {
  en: { sub:'Authentic Japanese Cuisine',     badge:'Interactive 3D & AR Preview',           veg:'veg',        loading:'読み込み中…' },
  jp: { sub:'本物の日本料理',                  badge:'インタラクティブ3DとARプレビュー',          veg:'ベジ',       loading:'読み込み中…' },
  kn: { sub:'ಅಧಿಕೃತ ಜಪಾನೀಸ್ ಆಹಾರ',         badge:'ಸಂವಾದಾತ್ಮಕ 3D ಮತ್ತು AR ಮುನ್ನೋಟ',       veg:'ಸಸ್ಯಹಾರಿ', loading:'ಲೋಡ್ ಆಗುತ್ತಿದೆ…' },
  ta: { sub:'உண்மையான ஜப்பானிய உணவு',       badge:'ஊடாடும் 3D மற்றும் AR மாதிரிக்காட்சி', veg:'சைவம்',      loading:'ஏற்றப்படுகிறது…' },
  ml: { sub:'ആധികാരിക ജാപ്പനീസ് വിഭവങ്ങൾ', badge:'ഇന്ററാക്ടീവ് 3D & AR പ്രിവ്യൂ',         veg:'വെജ്',       loading:'ലോഡ് ചെയ്യുന്നു…' },
  te: { sub:'ప్రామాణిక జపనీస్ వంటకాలు',     badge:'ఇంటరాక్టివ్ 3D & AR ప్రివ్యూ',          veg:'శాఖాహారం',   loading:'లోడ్ అవుతోంది…' },
};

const CAT_LABELS = {
  all:     { en:'All',        jp:'すべて',    kn:'ಎಲ್ಲವೂ',        ta:'அனைத்தும்',     ml:'എല്ലാം',         te:'అన్నీ' },
  starter: { en:'Starters',   jp:'スターター', kn:'ಆರಂಭಿಕಗಳು',    ta:'துவக்கிகள்',    ml:'സ്റ്റാർട്ടറുകൾ', te:'ప్రారంభకాలు' },
  ramen:   { en:'Ramen',      jp:'ラーメン',   kn:'ರಾಮೆನ್',        ta:'ராமன்',         ml:'രാമെൻ',          te:'రామెన్' },
  sushi:   { en:'Sushi',      jp:'寿司',       kn:'ಸುಶಿ',          ta:'சுஷி',          ml:'സുഷി',           te:'సుషీ' },
  rice:    { en:'Mains',      jp:'メイン',     kn:'ಮುಖ್ಯ ಆಹಾರ',   ta:'முக்கிய உணவு',  ml:'പ്രധാന ഭക്ഷണം',  te:'ప్రధాన వంటకాలు' },
  drinks:  { en:'Desserts',   jp:'デザート',   kn:'ಸಿಹಿತಿಂಡಿಗಳು', ta:'இனிப்புகள்',    ml:'ഡെസേർട്ടുകൾ',    te:'తీపి వంటకాలు' },
};

let allDishes = [], rawRows = [], activeCategory = 'all', currentLang = 'en';
const isIOS = /iPhone|iPad|iPod/i.test(navigator.userAgent) ||
              (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);

function parseCSV(text) {
  const lines = text.trim().split('\n');
  if (lines.length < 2) return [];
  const headers = splitLine(lines[0]).map(h => h.trim().toLowerCase());
  return lines.slice(1).map(line => {
    const vals = splitLine(line), obj = {};
    headers.forEach((h, i) => { obj[h] = (vals[i] || '').trim(); });
    return obj;
  });
}
function splitLine(line) {
  const result = []; let cur = '', inQ = false;
  for (let i = 0; i < line.length; i++) {
    const ch = line[i];
    if (ch === '"' && !inQ) { inQ = true; continue; }
    if (ch === '"' && inQ)  { if (line[i+1] === '"') { cur += '"'; i++; } else { inQ = false; } continue; }
    if (ch === ',' && !inQ) { result.push(cur); cur = ''; continue; }
    cur += ch;
  }
  result.push(cur); return result;
}

function rowToDish(row) {
  const truthy = v => ['true','yes','1'].includes((v||'').toLowerCase());
  const sfx  = currentLang !== 'en' ? `_${currentLang}` : '';
  const desc = row[`description${sfx}`] || row['description'] || '';
  const name = row[`name${sfx}`]        || row['name']        || '';
  const local = getLocalAssets(row['name'] || name);
  return {
    id:        row['id']       || '',
    name, category: (row['category'] || 'other').toLowerCase(),
    jp:        row['jp_name']  || '',
    desc,
    price:     parseInt(row['price'] || '0', 10),
    veg:       truthy(row['veg']),
    dotd:      truthy(row['dish of the day'] || row['dotd']),
    isNew:     truthy(row['new']),
    available: truthy(row['available']),
    glbPath:   local.glbPath,
    usdzPath:  local.usdzPath,
    posterPath: local.posterPath,
    scale:     local.scale,
    emoji:     EMOJI_MAP[(row['name']||'').toLowerCase()] || '🍽️',
  };
}

function tagHTML(d) {
  const t = I18N[currentLang] || I18N.en;
  return [
    d.veg   ? `<span class="tag tag-veg">🌿 ${t.veg}</span>` : '',
    d.isNew ? '<span class="tag tag-new">新 new</span>'       : '',
    d.dotd  ? '<span class="tag tag-dotd">★ chef\'s pick</span>' : '',
  ].join('');
}
function catLabel(cat) {
  const map = CAT_LABELS[cat];
  return map ? (map[currentLang] || map.en) : (cat.charAt(0).toUpperCase() + cat.slice(1));
}

function renderTabs() {
  const cats = ['all', ...new Set(allDishes.map(d => d.category))];
  const wrap = document.getElementById('tabs-inner');
  wrap.innerHTML = cats.map(c =>
    `<button class="tab-btn${c === activeCategory ? ' active' : ''}" data-cat="${c}">${catLabel(c)}</button>`
  ).join('');
  wrap.querySelectorAll('.tab-btn').forEach(btn =>
    btn.addEventListener('click', () => { activeCategory = btn.dataset.cat; renderTabs(); renderItems(); })
  );
}

const SVG_CUBE = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>`;

function cardHTML(d) {
  const thumbContent = d.posterPath
    ? `<img src="${d.posterPath}" alt="${d.name}" loading="lazy"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        ><span style="display:none;font-size:32px;width:100%;height:100%;align-items:center;justify-content:center;">${d.emoji}</span>`
    : `<span style="font-size:32px;">${d.emoji}</span>`;
  return `
    <div class="menu-card${d.available ? '' : ' unavailable'}" data-id="${d.id}" role="button" tabindex="0" aria-label="View ${d.name}">
      <div class="card-row">
        <div class="card-thumb">
          ${thumbContent}
          ${d.glbPath ? '<span class="ar-pill">AR</span>' : ''}
        </div>
        <div class="card-body">
          <div class="name-row">
            <span class="dish-name">${d.name}</span>
            ${d.jp ? `<span class="dish-jp">${d.jp}</span>` : ''}
          </div>
          <div class="tags-row">${tagHTML(d)}</div>
          <p class="dish-desc">${d.desc}</p>
          <div class="card-footer">
            <div class="dish-price"><span class="price-sym">₹</span>${d.price.toLocaleString('en-IN')}</div>
            ${d.glbPath ? `<button class="ar-btn" data-id="${d.id}">${SVG_CUBE} View in AR</button>` : ''}
          </div>
        </div>
      </div>
    </div>`;
}

function renderItems() {
  const filtered  = activeCategory === 'all' ? allDishes : allDishes.filter(d => d.category === activeCategory);
  const container = document.getElementById('items-container');
  if (activeCategory === 'all') {
    const grouped = {};
    filtered.forEach(d => { (grouped[d.category] = grouped[d.category] || []).push(d); });
    container.innerHTML = Object.entries(grouped).map(([cat, items]) =>
      `<div class="section-label"><span></span>${catLabel(cat)}<span></span></div>
       <div class="items-grid">${items.map(cardHTML).join('')}</div>`
    ).join('');
  } else {
    container.innerHTML = `<div class="items-grid">${filtered.map(cardHTML).join('')}</div>`;
  }
  container.querySelectorAll('.menu-card').forEach(card =>
    card.addEventListener('click', () => openModal(card.dataset.id))
  );
  container.querySelectorAll('.ar-btn').forEach(btn =>
    btn.addEventListener('click', e => { e.stopPropagation(); openModal(btn.dataset.id); })
  );
}

function openModal(id) {
  const d = allDishes.find(x => x.id === id);
  if (!d) return;
  document.getElementById('modal-name').textContent = d.name;
  document.getElementById('modal-jp').textContent   = d.jp;
  document.getElementById('modal-desc').textContent = d.desc;
  document.getElementById('modal-price').innerHTML  =
    `<span style="font-family:'Noto Sans JP',sans-serif;font-size:14px;color:var(--ink-faint)">₹</span>${d.price.toLocaleString('en-IN')}`;
  document.getElementById('modal-tags').innerHTML   = tagHTML(d);
  document.getElementById('modal-tags2').innerHTML  = tagHTML(d);

  const arBadge   = document.getElementById('mv-ar-badge');
  const scaleInfo = document.getElementById('scale-info');
  arBadge.classList.remove('visible');
  scaleInfo.textContent = '';

  const vw = document.getElementById('modal-viewer-wrap');
  vw.querySelectorAll('.modal-photo, model-viewer, .no-model, .mv-loading-overlay, .mv-ar-btn-wrap')
    .forEach(el => el.remove());

  const photoWrap = document.createElement('div');
  photoWrap.className = 'modal-photo';
  photoWrap.style.cssText = 'position:absolute;inset:0;display:flex;align-items:center;justify-content:center;overflow:hidden;';
  if (d.posterPath) {
    photoWrap.innerHTML = `
      <img src="${d.posterPath}" alt="${d.name}" style="width:100%;height:100%;object-fit:cover;"
        onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
      <span style="display:none;font-size:80px;align-items:center;justify-content:center;width:100%;height:100%;">${d.emoji}</span>`;
  } else {
    photoWrap.innerHTML = `<span style="font-size:80px;">${d.emoji}</span>`;
  }
  vw.insertBefore(photoWrap, arBadge);

  if (d.glbPath) {
    const arBtnWrap = document.createElement('div');
    arBtnWrap.className = 'mv-ar-btn-wrap';
    arBtnWrap.style.cssText = `position:absolute;bottom:16px;left:50%;transform:translateX(-50%);z-index:6;display:flex;gap:10px;align-items:center;`;
    arBtnWrap.innerHTML = `
      <button class="modal-ar-launch-btn" style="
        display:inline-flex;align-items:center;gap:8px;
        background:var(--crimson);color:var(--washi);
        border:none;padding:11px 24px;
        font-family:'Cinzel',serif;font-size:12px;font-weight:600;
        letter-spacing:2px;cursor:pointer;white-space:nowrap;min-height:44px;
        box-shadow:0 4px 18px rgba(139,26,26,0.45);">
        ✦ View On Table
      </button>`;
    vw.insertBefore(arBtnWrap, arBadge);
    arBtnWrap.querySelector('.modal-ar-launch-btn').addEventListener('click', () => {
      loadModelAndAR(d, vw, arBadge, scaleInfo, arBtnWrap, photoWrap);
    });
  }

  document.getElementById('modal-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function loadModelAndAR(d, vw, arBadge, scaleInfo, arBtnWrap, photoWrap) {
  const btn = arBtnWrap.querySelector('.modal-ar-launch-btn');
  btn.disabled = true;
  btn.innerHTML = `<span style="display:inline-block;width:14px;height:14px;border:2px solid rgba(245,237,224,0.3);border-top-color:var(--washi);border-radius:50%;animation:spin 0.8s linear infinite;"></span> 読込中…`;

  const mv = document.createElement('model-viewer');
  mv.setAttribute('src', d.glbPath);
  if (isIOS && d.usdzPath) mv.setAttribute('ios-src', d.usdzPath);

  // Scale: applied in 3D preview only. AR uses ar-scale="auto" so Scene Viewer
  // / WebXR auto-fits the model to real-world size from GLTF units — fastest & most accurate.
  const s = (d.scale ?? 1).toFixed(6);
  mv.setAttribute('scale',             `${s} ${s} ${s}`);
  mv.setAttribute('ar',               '');
  mv.setAttribute('ar-modes',         'webxr scene-viewer quick-look');
  mv.setAttribute('ar-placement',     'floor');
  mv.setAttribute('ar-scale',         'auto');          // auto-fit to environment
  mv.setAttribute('camera-controls',  '');
  mv.setAttribute('camera-orbit',     '0deg 75deg auto');
  mv.setAttribute('min-camera-orbit', 'auto 10deg 0.1m');
  mv.setAttribute('max-camera-orbit', 'auto 90deg 10m');
  mv.setAttribute('field-of-view',    'auto');
  mv.setAttribute('shadow-intensity', '1');
  mv.setAttribute('shadow-softness',  '0.8');
  mv.setAttribute('environment-image','neutral');
  mv.setAttribute('exposure',         '1.1');
  mv.setAttribute('interaction-prompt','none');
  mv.setAttribute('loading',          'eager');
  mv.setAttribute('reveal',           'auto');
  mv.setAttribute('touch-action',     'pan-y');          // allow pinch-zoom on model
  mv.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;background:transparent;touch-action:pan-y pinch-zoom;z-index:-1;opacity:0;pointer-events:none;';

  // Insert into DOM AFTER all attributes are set (Scene Viewer reads scale from launch URL)
  vw.insertBefore(mv, arBadge);

  mv.addEventListener('load', () => {
    // Log natural dimensions so you can calibrate LOCAL_ASSETS scale values
    if (mv.getDimensions) {
      const dim = mv.getDimensions();
      console.log(`[AR] ${d.name} natural dims:`, dim, `| applied scale: ${s}`);
    }

    // Show the 3D model in the viewer panel (interactive with pinch-zoom)
    photoWrap.style.display = 'none';
    mv.style.zIndex = '2';
    mv.style.opacity = '1';
    mv.style.pointerEvents = 'auto';
    arBadge.classList.add('visible');
    arBtnWrap.style.display = 'flex';
    btn.disabled = false;
    btn.innerHTML = '✦ Launch AR';

    // Auto-launch AR immediately
    mv.activateAR();

    mv.addEventListener('ar-status', (e) => {
      if (e.detail.status === 'failed' || e.detail.status === 'not-presenting') {
        btn.disabled = false;
        btn.innerHTML = '✶ View in AR';
      }
    }, { once: true });
  });

  mv.addEventListener('error', () => {
    btn.disabled = false;
    btn.innerHTML = '⚠ Retry';
    mv.remove();
  });
}

function closeModal() {
  const mvEl = document.querySelector('#modal-viewer-wrap model-viewer');
  if (mvEl && typeof mvEl.pause === 'function') mvEl.pause();
  document.getElementById('modal-overlay').classList.remove('open');
  document.body.style.overflow = '';
  document.querySelectorAll('#modal-viewer-wrap .modal-photo, #modal-viewer-wrap model-viewer, #modal-viewer-wrap .mv-loading-overlay, #modal-viewer-wrap .mv-ar-btn-wrap')
    .forEach(el => el.remove());
  document.getElementById('mv-ar-badge').classList.remove('visible');
}

document.addEventListener('visibilitychange', () => {
  const mvEl = document.querySelector('#modal-viewer-wrap model-viewer');
  if (!mvEl) return;
  document.hidden ? (typeof mvEl.pause==='function' && mvEl.pause()) : (typeof mvEl.play==='function' && mvEl.play());
});

document.getElementById('modal-close').addEventListener('click', closeModal);
document.getElementById('modal-overlay').addEventListener('click', e => {
  if (e.target === document.getElementById('modal-overlay')) closeModal();
});
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

document.getElementById('lang-select').addEventListener('change', e => {
  currentLang = e.target.value;
  const t = I18N[currentLang] || I18N.en;
  document.getElementById('ui-sub-tag').textContent  = t.sub;
  document.getElementById('ui-ar-badge').textContent = t.badge;
  document.getElementById('ui-loading').textContent  = t.loading;
  allDishes = rawRows.map(rowToDish).filter(d => d.name);
  renderTabs(); renderItems();
});

async function init() {
  const loadingEl = document.getElementById('loading-state');
  const container = document.getElementById('items-container');
  try {
    const res  = await fetch(CSV_URL);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const text = await res.text();
    rawRows    = parseCSV(text);
    allDishes  = rawRows.map(rowToDish).filter(d => d.name);
    if (!allDishes.length) throw new Error('No dishes found.');
    loadingEl.style.display = 'none';
    container.style.display = 'block';
    renderTabs(); renderItems();
  } catch (err) {
    console.error('Menu load error:', err);
    loadingEl.innerHTML = `
      <p style="color:var(--crimson);font-family:'Cinzel',serif;letter-spacing:2px;margin-bottom:10px">Could not load menu</p>
      <p style="font-size:13px;line-height:1.8;color:var(--ink-light)">
        Make sure your sheet is published:<br>
        <strong>File → Share → Publish to web → CSV</strong><br><br>
        Sheet ID:<br>
        <code style="background:var(--washi-deep);padding:3px 8px;font-size:11px">${SHEET_ID}</code>
      </p>`;
  }
}
init();
</script>
</body>
</html>
