<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
  <title>Pinocchio — AR Menu</title>
  <meta name="description" content="Interactive AR menu for Pinocchio — authentic Italian cuisine with 3D dish previews." />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="dns-prefetch" href="https://unpkg.com" />
  <link rel="dns-prefetch" href="https://docs.google.com" />

  <link rel="preload"
        href="https://docs.google.com/spreadsheets/d/e/2PACX-1vTEkmIGoRgD1rQNmDgmY3lvB7WBOg86iOHHrS0MJ6qQiReuDHsUyX3YV7KoWXxTbefyBUWPTHpvUOt3/pub?output=csv"
        as="fetch" crossorigin="anonymous" />

  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <noscript>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </noscript>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --font-serif:   'Playfair Display', 'Georgia', serif;
      --font-sans:    'Inter', 'Helvetica Neue', sans-serif;
      --font-display: 'Cinzel', serif;
      --font-body:    'Cormorant Garamond', Georgia, serif;

      --washi:        #efe2cf;
      --washi-dark:   #e2d1b8;
      --washi-deep:   #d4bea0;
      --ink:          #2c120f;
      --ink-mid:      #4e231b;
      --ink-light:    #7b5647;
      --ink-faint:    #a07d69;
      --crimson:      #8d1d2d;
      --crimson-mid:  #a32133;
      --crimson-lt:   #c74456;
      --gold:         #c39a5c;
      --gold-lt:      #ddb777;
      --gold-pale:    #f1d7a4;
      --sage:         #567a47;
      --sage-lt:      #dce9d0;
      --shadow-ink:   rgba(44,18,15,0.14);
      --shadow-deep:  rgba(44,18,15,0.24);
    }

    html { scroll-behavior: smooth; }

    body {
      background: linear-gradient(180deg, #3f0d14 0%, #5b111b 30%, #701826 60%, #3a0d12 100%);
      color: #f3e8d7;
      min-height: 100vh;
      font-family: var(--font-sans);
    }

    /* Subtle fine-line grid overlay to evoke a premium wine list / menu feel instead of wave rings */
    .menu-texture-bg {
      position: absolute; inset: 0; opacity: 0.03;
      background-size: 20px 20px;
      background-image: linear-gradient(to right, #8b1a1a 1px, transparent 1px), linear-gradient(to bottom, #8b1a1a 1px, transparent 1px);
      pointer-events: none;
    }

    .site-header {
      position: relative; overflow: hidden;
      background: linear-gradient(145deg, #3d0f13 0%, #5a1520 50%, #3d0f13 100%);
      color: #f5ede0; text-align: center;
      padding: max(env(safe-area-inset-top), 2.5rem) 1rem 2.5rem;
    }
    .site-header .menu-texture-bg { opacity: 0.04; }
    .site-header::before {
      content: ''; position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 80% 60% at 20% 80%, rgba(139,26,26,0.18) 0%, transparent 70%),
        radial-gradient(ellipse 60% 80% at 80% 20%, rgba(154,120,32,0.14) 0%, transparent 60%);
      pointer-events: none;
    }
    .site-header::after {
      content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, transparent, var(--crimson-mid), var(--gold-lt), var(--crimson-mid), transparent);
    }
    .header-mon {
      width: 52px; height: 52px; border: 1.5px solid rgba(196,160,48,0.5);
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      margin: 0 auto 14px; position: relative; animation: monSpin 20s linear infinite;
    }
    @keyframes monSpin { to { transform: rotate(360deg); } }
    .header-brand {
      font-family: var(--font-serif); font-size: clamp(11px,2.5vw,13px);
      letter-spacing: 6px; color: rgba(245,237,224,0.4); margin-bottom: 10px; text-transform: uppercase;
    }
    .header-title {
      font-family: var(--font-display); font-size: clamp(30px,6.5vw,54px);
      font-weight: 600; letter-spacing: 0.08em; line-height: 1; margin-bottom: 6px;
      background: linear-gradient(160deg, #f5ede0 30%, var(--gold-pale) 65%, #f5ede0 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .header-title-sub {
      font-family: var(--font-serif); font-size: clamp(16px,4vw,24px);
      font-weight: 300; color: rgba(245,237,224,0.6); letter-spacing: 0.2em;
      margin-bottom: 14px; display: block; italic;
    }
    .header-sub {
      font-size: 11px; letter-spacing: 4px; text-transform: uppercase;
      color: rgba(245,237,224,0.38); margin-bottom: 20px;
    }
    .brush-divider {
      width: 120px; height: 2px;
      background: linear-gradient(90deg, transparent, var(--crimson-mid), transparent);
      margin: 0 auto 18px; position: relative;
    }
    .brush-divider::before, .brush-divider::after {
      content: '◆'; position: absolute; top: 50%; transform: translateY(-50%);
      font-size: 6px; color: var(--gold-lt);
    }
    .brush-divider::before { left: 18px; }
    .brush-divider::after  { right: 18px; }
    .ar-badge {
      display: inline-flex; align-items: center; gap: 8px;
      border: 1px solid rgba(196,160,48,0.3); border-radius: 2px;
      padding: 7px 18px; font-size: 11px; letter-spacing: 2px;
      color: rgba(245,237,224,0.55); font-family: var(--font-sans);
      background: rgba(154,120,32,0.08);
    }
    .ar-dot {
      width: 6px; height: 6px; border-radius: 50%; background: var(--crimson-mid);
      flex-shrink: 0; animation: pulse 1.8s ease-in-out infinite;
    }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.3;transform:scale(0.7)} }
    #language-picker { position: relative; z-index: 10; margin-bottom: 18px; }
    #lang-select {
      background: rgba(245,237,224,0.08); color: rgba(245,237,224,0.7);
      border: 1px solid rgba(196,160,48,0.25); border-radius: 2px;
      padding: 7px 12px; font-family: var(--font-sans);
      font-size: 12px; cursor: pointer; outline: none; letter-spacing: 1px;
    }
    #lang-select option { background: #1c1108; color: #f5ede0; }

    .tabs-wrap {
      position: sticky; top: 0; z-index: 100;
      background: rgba(243,232,215,0.97);
      border-bottom: 1px solid rgba(139,26,26,0.2);
      padding: 0 1rem;
    }
    .tabs-inner {
      max-width: 740px; margin: 0 auto;
      display: flex; gap: 2px; overflow-x: auto; scrollbar-width: none; padding: 10px 0;
    }
    .tabs-inner::-webkit-scrollbar { display: none; }
    .tab-btn {
      flex-shrink: 0; padding: 6px 18px; border: 1px solid rgba(139,26,26,0.18);
      background: transparent; color: var(--ink-faint);
      font-family: var(--font-sans); font-size: 12px; letter-spacing: 1px;
      cursor: pointer; transition: all 0.2s ease; white-space: nowrap; border-radius: 1px;
    }
    .tab-btn:hover { border-color: var(--crimson); color: var(--crimson); background: rgba(139,26,26,0.04); }
    .tab-btn.active { background: var(--crimson); color: var(--washi); border-color: var(--crimson); box-shadow: 0 2px 12px rgba(139,26,26,0.3); }

    .main { max-width: 740px; margin: 0 auto; padding: 1.5rem 1rem 5rem; }

    .skeleton-grid { display: flex; flex-direction: column; gap: 10px; }
    .skeleton-card {
      background: rgba(243,232,215,0.5); border-radius: 1px;
      padding: 1.1rem 1.25rem; border: 1px solid rgba(214,178,126,0.18);
      border-left: 3px solid rgba(139,26,26,0.15);
      animation: shimmer 1.4s ease-in-out infinite;
    }
    .skeleton-card .sk-row { display: flex; gap: 14px; }
    .skeleton-card .sk-thumb { width: 68px; height: 68px; flex-shrink: 0; background: rgba(139,26,26,0.12); border-radius: 1px; }
    .skeleton-card .sk-body { flex: 1; display: flex; flex-direction: column; gap: 8px; justify-content: center; }
    .skeleton-card .sk-line { height: 12px; background: rgba(139,26,26,0.1); border-radius: 2px; }
    .skeleton-card .sk-line.wide { width: 65%; }
    .skeleton-card .sk-line.full { width: 100%; }
    .skeleton-card .sk-line.mid  { width: 45%; }
    .skeleton-card .sk-line.short { width: 30%; }
    @keyframes shimmer { 0%,100% { opacity: 0.7; } 50% { opacity: 1; } }

    .state-box { text-align: center; padding: 4rem 1rem; color: var(--ink-faint); }
    .state-box .spinner {
      width: 36px; height: 36px; border: 2px solid rgba(139,26,26,0.15);
      border-top-color: var(--crimson); border-radius: 50%;
      animation: spin 0.9s linear infinite; margin: 0 auto 1rem; background: transparent;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .state-box p { font-size: 13px; font-family: var(--font-serif); letter-spacing: 2px; }
    
    .section-label {
      display: flex; align-items: center; gap: 14px; margin: 2rem 0 1rem;
      font-family: var(--font-serif); font-size: 11px; letter-spacing: 4px;
      text-transform: uppercase; color: #f0d2a0;
    }
    .section-label span { flex: 1; height: 1px; background: linear-gradient(90deg, transparent, rgba(139,26,26,0.3), transparent); }
    .section-label::before { content: '◈'; font-size: 10px; color: var(--gold); flex-shrink: 0; }

    .items-grid { display: flex; flex-direction: column; gap: 10px; }
    .menu-card {
      background: rgba(243,232,215,0.96); border: 1px solid rgba(214,178,126,0.18);
      border-left: 3px solid transparent; border-radius: 1px; padding: 1.1rem 1.25rem;
      cursor: pointer;
      transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s, background 0.2s;
      -webkit-tap-highlight-color: transparent; position: relative; overflow: hidden;
      content-visibility: auto;
      contain-intrinsic-size: auto 100px;
    }
    .menu-card:hover {
      border-left-color: var(--crimson); transform: translateX(3px);
      box-shadow: -4px 0 0 var(--crimson), 3px 4px 18px var(--shadow-ink);
      background: rgba(255,252,248,0.95);
    }
    .card-row { display: flex; gap: 14px; align-items: flex-start; }
    .card-thumb {
      width: 68px; height: 68px; flex-shrink: 0; border-radius: 1px;
      background: linear-gradient(135deg, var(--washi-dark) 0%, var(--washi-deep) 100%);
      border: 1px solid rgba(139,26,26,0.15); display: flex; align-items: center; justify-content: center;
      font-size: 32px; position: relative; overflow: hidden;
    }
    .card-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; decoding: async; }
    .ar-pill {
      position: absolute; bottom: 2px; right: 2px; background: var(--crimson);
      color: var(--washi); font-size: 7px; letter-spacing: 1px; padding: 2px 5px;
      font-family: var(--font-display); line-height: 1.4;
    }
    .card-body { flex: 1; min-width: 0; }
    .name-row { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; margin-bottom: 4px; }
    .dish-name { font-family: var(--font-body); font-size: 19px; font-weight: 600; color: var(--ink); letter-spacing: 0.02em; }
    .dish-jp { font-family: var(--font-serif); font-size: 12px; font-weight: 300; color: var(--ink-faint); letter-spacing: 1px; }
    
    .tags-row { display: flex; gap: 5px; flex-wrap: wrap; margin: 5px 0 7px; }
    .tag { font-size: 10px; padding: 2px 9px; font-family: var(--font-sans); font-weight: 500; letter-spacing: 0.5px; border-radius: 1px; }
    .tag-veg  { background: var(--sage-lt); color: var(--sage); border: 1px solid rgba(74,103,65,0.2); }
    .tag-new  { background: rgba(139,26,26,0.08); color: var(--crimson); border: 1px solid rgba(139,26,26,0.2); }
    .tag-dotd { background: rgba(154,120,32,0.1); color: var(--gold); border: 1px solid rgba(154,120,32,0.25); }
    
    .dish-desc { font-size: 12.5px; color: var(--ink-light); line-height: 1.65; margin-bottom: 10px; font-family: var(--font-sans); }
    .card-footer { display: flex; align-items: center; justify-content: space-between; }
    .dish-price { font-family: var(--font-body); font-size: 22px; font-weight: 600; color: var(--ink); }
    .price-sym { font-family: var(--font-sans); font-size: 12px; color: var(--ink-faint); margin-right: 1px; }
    
    .ar-btn {
      display: inline-flex; align-items: center; gap: 6px; background: var(--ink);
      color: var(--washi); border: none; padding: 8px 16px;
      font-family: var(--font-sans); font-size: 11px; letter-spacing: 1px;
      cursor: pointer; transition: background 0.18s, box-shadow 0.18s;
      -webkit-tap-highlight-color: transparent; min-height: 44px; border-radius: 1px; position: relative;
    }
    .ar-btn::before { content: ''; position: absolute; inset: 0; background: var(--crimson); opacity: 0; transition: opacity 0.18s; }
    .ar-btn:hover::before { opacity: 1; }
    .ar-btn:hover { box-shadow: 0 4px 14px rgba(139,26,26,0.4); }
    .ar-btn > * { position: relative; z-index: 1; }
    .ar-btn svg { width: 13px; height: 13px; flex-shrink: 0; }

    /* ── MODAL ── */
    .modal-overlay {
      display: none; position: fixed; inset: 0; background: rgba(10,6,2,0.88);
      z-index: 9000; align-items: flex-end; justify-content: center;
      padding: 0; backdrop-filter: blur(2px);
    }
    @media (min-width: 540px) { .modal-overlay { align-items: center; padding: 1.5rem; } }
    .modal-overlay.open { display: flex; }
    .modal-card {
      background: #f3e8d7; border-top: 3px solid var(--crimson);
      width: 100%; max-width: 520px; max-height: 92svh;
      overflow-y: auto; overscroll-behavior: contain; position: relative;
      animation: slideUp 0.28s cubic-bezier(0.22,1,0.36,1);
    }
    @media (min-width: 540px) {
      .modal-card { border-top: none; border: 1px solid rgba(139,26,26,0.2); border-radius: 2px; animation: fadeIn 0.22s ease; }
    }
    @keyframes slideUp { from { transform: translateY(50px); opacity: 0; } to { transform: none; opacity: 1; } }
    @keyframes fadeIn  { from { opacity: 0; transform: scale(0.96) translateY(8px); } to { opacity: 1; transform: none; } }
    
    .modal-viewer-wrap {
      width: 100%; height: 300px;
      background: linear-gradient(160deg, #120c05 0%, #1e1208 50%, #120c05 100%);
      position: relative; overflow: hidden;
    }
    .modal-viewer-wrap::before {
      content: ''; position: absolute; inset: 12px;
      border: 1px solid rgba(196,160,48,0.18); pointer-events: none; z-index: 3;
    }

    #mv-wrapper { position: absolute; inset: 0; z-index: 2; opacity: 0; transition: opacity 0.35s ease; pointer-events: none; }
    #mv-wrapper.mv-visible { opacity: 1; pointer-events: auto; }

    model-viewer {
      display: block; width: 100%; height: 300px; background: transparent;
      --progress-bar-color: #b8860b; --progress-mask: transparent;
      touch-action: pan-y pinch-zoom; position: absolute; inset: 0;
    }
    model-viewer > [slot="ar-button"] { display: none !important; }

    .mv-ar-badge {
      position: absolute; top: 10px; left: 50%; transform: translateX(-50%) translateY(-8px);
      background: rgba(20,12,4,0.92); border: 1px solid var(--gold);
      padding: 4px 14px; font-family: var(--font-display); font-size: 9px; letter-spacing: 2px;
      color: var(--gold-pale); text-transform: uppercase; opacity: 0; transition: opacity 0.4s, transform 0.4s;
      pointer-events: none; z-index: 4; white-space: nowrap;
    }
    .mv-ar-badge.visible { opacity: 1; transform: translateX(-50%) translateY(0); }
    .scale-info {
      position: absolute; bottom: 10px; left: 50%; transform: translateX(-50%);
      background: rgba(20,12,4,0.85); border: 1px solid rgba(196,160,48,0.2);
      padding: 4px 14px; font-family: var(--font-sans); font-size: 9px; letter-spacing: 2px;
      color: rgba(245,237,224,0.45); text-transform: uppercase; white-space: nowrap; z-index: 4; pointer-events: none;
    }
    .modal-close {
      position: absolute; top: 12px; right: 12px; width: 36px; height: 36px;
      background: rgba(10,6,2,0.6); border: 1px solid rgba(196,160,48,0.2);
      color: rgba(245,237,224,0.7); font-size: 16px; display: flex; align-items: center; justify-content: center;
      cursor: pointer; z-index: 10; transition: background 0.15s, border-color 0.15s; font-family: serif;
    }
    .modal-close:hover { background: var(--crimson); border-color: var(--crimson); color: var(--washi); }

    .mv-loader {
      position: absolute; inset: 0; z-index: 5; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px;
      background: linear-gradient(160deg, #120c05 0%, #1e1208 50%, #120c05 100%); transition: opacity 0.3s;
    }
    .mv-loader.hidden { opacity: 0; pointer-events: none; }
    .mv-loader-ring { width: 40px; height: 40px; border-radius: 50%; border: 2px solid rgba(196,160,48,0.15); border-top-color: var(--gold); animation: spin 0.8s linear infinite; }
    .mv-loader-text { font-family: var(--font-display); font-size: 10px; letter-spacing: 3px; color: var(--gold-pale); opacity: 0.6; }

    .modal-body { padding: 1.5rem 1.6rem 2rem; }
    .modal-name { font-family: var(--font-display); font-size: 26px; font-weight: 600; letter-spacing: 0.05em; color: var(--ink); margin-bottom: 2px; }
    .modal-jp { font-family: var(--font-serif); font-size: 14px; font-weight: 300; color: var(--ink-faint); letter-spacing: 3px; margin-bottom: 12px; }
    .modal-desc { font-size: 13.5px; color: var(--ink-light); line-height: 1.75; padding: 12px 16px; border-left: 3px solid var(--crimson); background: rgba(139,26,26,0.04); margin-bottom: 18px; font-family: var(--font-sans); }
    .modal-footer { display: flex; align-items: center; justify-content: space-between; padding-top: 14px; border-top: 1px solid rgba(139,26,26,0.15); }
    .modal-price { font-family: var(--font-body); font-size: 32px; font-weight: 600; color: var(--ink); }

    .mv-ar-btn-wrap { position: absolute; bottom: 16px; left: 50%; transform: translateX(-50%); z-index: 6; display: none; gap: 10px; align-items: center; }
    .modal-ar-launch-btn {
      display: inline-flex; align-items: center; gap: 8px; background: var(--crimson); color: var(--washi);
      border: none; padding: 11px 24px; font-family: var(--font-display); font-size: 12px; font-weight: 600;
      letter-spacing: 2px; cursor: pointer; white-space: nowrap; min-height: 44px; box-shadow: 0 4px 18px rgba(139,26,26,0.45); transition: opacity 0.15s;
    }
    .modal-ar-launch-btn:disabled { opacity: 0.6; cursor: not-allowed; }

    /* Adjusted color blend from beige to a rich transparent dark tint to match the wine aesthetic background */
    .site-footer {
      text-align: center; padding: 1.8rem 1rem; font-size: 11px; letter-spacing: 2px;
      background: rgba(40, 10, 15, 0.6); color: #d8b98e; border-top: 1px solid rgba(139,26,26,0.15);
      line-height: 2; font-family: var(--font-serif); position: relative;
    }
    .site-footer::before { content: '✿  ✿  ✿'; display: block; color: var(--crimson); opacity: 0.4; font-size: 14px; letter-spacing: 8px; margin-bottom: 8px; }
    .menu-card.unavailable { opacity: 0.4; pointer-events: none; }
    
    .funzone-btn {
      display: inline-flex; align-items: center; gap: 6px; background: linear-gradient(135deg, var(--crimson), var(--gold));
      color: var(--washi); text-decoration: none; padding: 8px 16px; font-family: var(--font-sans); font-size: 11px; font-weight: 500;
      letter-spacing: 1px; box-shadow: 0 4px 14px rgba(139,26,26,0.4); transition: opacity 0.15s;
    }
    .funzone-btn:hover { opacity: 0.85; }

    .ar-not-supported {
      display: none; position: absolute; bottom: 16px; left: 50%; transform: translateX(-50%); z-index: 6;
      background: rgba(20,12,4,0.92); border: 1px solid rgba(196,160,48,0.3); padding: 8px 18px; font-family: var(--font-sans);
      font-size: 11px; color: rgba(245,237,224,0.6); letter-spacing: 1px; white-space: nowrap; text-align: center;
    }
  </style>
</head>
<body>

<header class="site-header">
  <div class="menu-texture-bg"></div>
  <div style="position:absolute;top:max(env(safe-area-inset-top),1rem);right:1rem;z-index:20;">
    <a href="FunZone.html" class="funzone-btn">🎮 FunZone</a>
  </div>
  <div id="language-picker">
    <select id="lang-select">
      <option value="en">English</option>
      <option value="it">Italiano</option>
      <option value="kn">ಕನ್ನಡ</option>
      <option value="ta">தமிழ்</option>
      <option value="ml">മലയാളം</option>
      <option value="te">తెలుగు</option>
    </select>
  </div>
  <div class="header-mon"></div>
  <p class="header-brand">Italian Cuisine</p>
  <h1 class="header-title">PINOCCHIO</h1>
  <span class="header-title-sub">by Chef Giuseppe</span>
  <div class="brush-divider"></div>
  <p class="header-sub" id="ui-sub-tag">Authentic Italian Cuisine</p>
  <span class="ar-badge">
    <span class="ar-dot"></span>
    <span id="ui-ar-badge">Interactive 3D &amp; AR Preview</span>
  </span>
</header>

<nav class="tabs-wrap" aria-label="Menu categories">
  <div class="tabs-inner" id="tabs-inner">
    </div>
</nav>

<main class="main">
  <div id="items-container">
